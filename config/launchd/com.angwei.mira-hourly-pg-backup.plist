<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.angwei.mira-hourly-pg-backup</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/python3</string>
    <string>/Users/angwei/Sandbox/Mira/scripts/hourly_pg_backup.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/angwei/Sandbox/Mira</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StartInterval</key>
  <integer>3600</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/angwei/Sandbox/Mira/data/logs/hourly-pg-backup.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/angwei/Sandbox/Mira/data/logs/hourly-pg-backup.err.log</string>
</dict>
</plist>
